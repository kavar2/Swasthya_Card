<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Swasthya Card — Health ID Prototype</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');

  :root{
    --bg:#10262A;
    --surface:#173537;
    --surface-2:#1E4143;
    --paper:#F4ECD8;
    --marigold:#E8A33D;
    --marigold-dark:#8A5A16;
    --teal:#2E8C82;
    --alert:#C1443C;
    --alert-bg:#F6D9D6;
    --ink:#1C2321;
    --ink-light:#EDE6D3;
    --muted:#9FB3B0;
    --border:#2C4E4F;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink-light);
    font-family:'IBM Plex Sans', sans-serif;
    min-height:100vh;
  }
  .app{max-width:1180px;margin:0 auto;padding:28px 24px 60px;}
  header{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;margin-bottom:8px;border-bottom:1px solid var(--border);padding-bottom:18px;}
  header h1{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin:0;color:var(--ink-light);}
  header p{margin:4px 0 0;color:var(--muted);font-size:13px;}
  .badge-shared{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--marigold);background:rgba(232,163,61,0.12);border:1px solid rgba(232,163,61,0.4);padding:4px 10px;border-radius:20px;margin-top:8px;}
  nav{display:flex;gap:8px;}
  nav button{
    font-family:'IBM Plex Sans';font-size:13px;font-weight:500;
    background:transparent;color:var(--ink-light);border:1px solid var(--border);
    padding:9px 16px;border-radius:8px;cursor:pointer;transition:all .15s;
  }
  nav button.active{background:var(--marigold);color:#3A2400;border-color:var(--marigold);}
  nav button:hover:not(.active){border-color:var(--teal);}

  .layout{display:grid;grid-template-columns:280px 1fr;gap:24px;margin-top:24px;}
  @media (max-width:820px){.layout{grid-template-columns:1fr;}}

  .sidebar{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;height:fit-content;}
  .sidebar h3{font-size:12px;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin:0 0 12px;font-weight:600;}
  .search{width:100%;padding:9px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--ink-light);font-size:13px;margin-bottom:12px;}
  .patient-row{display:flex;justify-content:space-between;align-items:center;padding:10px 8px;border-radius:8px;cursor:pointer;font-size:13px;margin-bottom:4px;border:1px solid transparent;}
  .patient-row:hover{background:var(--surface-2);}
  .patient-row.selected{border-color:var(--marigold);background:rgba(232,163,61,0.1);}
  .patient-row .pname{font-weight:500;}
  .patient-row .pblood{font-family:'IBM Plex Mono';font-size:11px;color:var(--marigold);}
  .new-btn{width:100%;margin-top:10px;padding:10px;border-radius:8px;border:1px dashed var(--teal);background:transparent;color:var(--teal);font-size:13px;cursor:pointer;font-weight:500;}
  .new-btn:hover{background:rgba(46,140,130,0.12);}
  .empty-list{color:var(--muted);font-size:12px;padding:8px 0;}

  .stage{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;min-height:420px;}

  /* FORM */
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  .form-grid .full{grid-column:1/-1;}
  label{display:block;font-size:12px;color:var(--muted);margin-bottom:6px;font-weight:500;}
  input,select,textarea{width:100%;padding:9px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--ink-light);font-family:'IBM Plex Sans';font-size:13px;}
  textarea{resize:vertical;min-height:44px;}
  .form-actions{display:flex;gap:10px;margin-top:18px;}
  .btn-primary{background:var(--marigold);color:#3A2400;border:none;padding:10px 20px;border-radius:8px;font-weight:600;cursor:pointer;font-size:13px;}
  .btn-secondary{background:transparent;border:1px solid var(--border);color:var(--ink-light);padding:10px 20px;border-radius:8px;cursor:pointer;font-size:13px;}
  .btn-danger{background:transparent;border:1px solid var(--alert);color:#F0918C;padding:10px 20px;border-radius:8px;cursor:pointer;font-size:13px;margin-left:auto;}

  /* CARD */
  .card-wrap{display:flex;flex-direction:column;align-items:center;gap:16px;}
  .flip-scene{width:380px;height:230px;perspective:1400px;}
  .flip-card{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .6s;}
  .flip-card.flipped{transform:rotateY(180deg);}
  .face{position:absolute;inset:0;backface-visibility:hidden;border-radius:14px;padding:20px;background:var(--paper);color:var(--ink);box-shadow:0 8px 20px rgba(0,0,0,0.35);}
  .face-back{transform:rotateY(180deg);overflow-y:auto;}
  .card-top{display:flex;justify-content:space-between;align-items:flex-start;}
  .scheme-label{font-family:'IBM Plex Mono';font-size:9px;letter-spacing:0.08em;text-transform:uppercase;color:var(--marigold-dark);}
  .card-name{font-family:'Fraunces',serif;font-weight:600;font-size:20px;margin:10px 0 2px;line-height:1.15;}
  .card-id{font-family:'IBM Plex Mono';font-size:11px;color:#555;}
  .card-bottom{display:flex;justify-content:space-between;align-items:flex-end;margin-top:16px;}
  .blood-chip{background:var(--alert);color:var(--alert-bg);font-family:'IBM Plex Mono';font-weight:500;font-size:13px;padding:5px 10px;border-radius:6px;}
  .qr-stamp{width:64px;height:64px;background:#fff;border-radius:6px;padding:4px;display:flex;align-items:center;justify-content:center;}
  .qr-stamp img,.qr-stamp canvas{width:56px;height:56px;}
  .back-title{font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:#7A6E4E;font-weight:600;margin:0 0 4px;}
  .back-section{margin-bottom:10px;}
  .back-value{font-size:13px;line-height:1.4;}
  .allergy-pill{display:inline-block;background:var(--alert);color:var(--alert-bg);font-size:11px;padding:2px 8px;border-radius:10px;margin:2px 4px 0 0;}
  .med-pill{display:inline-block;background:var(--teal);color:#DFF5F1;font-size:11px;padding:2px 8px;border-radius:10px;margin:2px 4px 0 0;}
  .card-controls{display:flex;gap:10px;}
  .payload-toggle{font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline;background:none;border:none;}
  .payload-box{width:100%;max-width:520px;font-family:'IBM Plex Mono';font-size:10.5px;color:var(--muted);background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px;word-break:break-all;display:none;}
  .payload-box.show{display:block;}

  /* SCAN VIEW */
  .scan-hint{color:var(--muted);font-size:13px;margin-bottom:18px;}
  .scan-result{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:20px;margin-top:16px;}
  .scan-result h2{font-family:'Fraunces',serif;font-size:20px;margin:0 0 2px;color:var(--ink-light);}
  .scan-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;}
  .scan-field{border-left:2px solid var(--marigold);padding-left:10px;}
  .scan-field .k{font-size:11px;text-transform:uppercase;color:var(--muted);letter-spacing:0.05em;}
  .scan-field .v{font-size:14px;margin-top:2px;}
  .scan-field.danger{border-left-color:var(--alert);}
  .scan-field.danger .v{color:#F0918C;}
  .qr-select{margin-bottom:14px;}
  .placeholder{color:var(--muted);text-align:center;padding:60px 20px;font-size:14px;}
  .sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);}
</style>
</head>
<body>
<div class="app">
  <header>
    <div>
      <h1>Swasthya Card <span style="color:var(--muted); font-weight:400; font-size:16px;">— health ID prototype</span></h1>
      <p>Inspired by Ayushman Bharat / ABHA-style digital health IDs. A QR carries emergency-critical data offline; a shared record store keeps it current.</p>
      <span class="badge-shared">This demo's patient list is shared — anyone with this artifact open can see it</span>
    </div>
    <nav id="nav">
      <button data-view="registry" class="active">Patient registry</button>
      <button data-view="scan">Emergency scan</button>
    </nav>
  </header>

  <div class="layout">
    <aside class="sidebar">
      <h3>Registered patients</h3>
      <input class="search" id="search" placeholder="Search by name or ID">
      <div id="patientList"></div>
      <button class="new-btn" id="newPatientBtn">+ Register new patient</button>
    </aside>

    <main class="stage" id="stage">
      <div class="placeholder">Loading…</div>
    </main>
  </div>
</div>

<script>
let index = [];
let selectedId = null;
let currentView = 'registry';
let cardFlipped = false;
let qrInstance = null;

const stage = document.getElementById('stage');
const patientListEl = document.getElementById('patientList');
const bloodGroups = ['A+','A-','B+','B-','AB+','AB-','O+','O-'];

// Falls back to localStorage when running outside the Claude artifact sandbox
// (window.storage only exists inside claude.ai artifacts).
const hasClaudeStorage = typeof window !== 'undefined' && !!window.storage;
const LS_PREFIX = 'swasthya:';

async function safeGet(key, shared){
  if(hasClaudeStorage){
    try{ const r = await window.storage.get(key, shared); return r ? r.value : null; }
    catch(e){ return null; }
  }
  try{ return localStorage.getItem(LS_PREFIX + key); }
  catch(e){ return null; }
}
async function safeSet(key, value, shared){
  if(hasClaudeStorage){
    try{ return await window.storage.set(key, value, shared); }
    catch(e){ console.error('storage set failed', e); return null; }
  }
  try{ localStorage.setItem(LS_PREFIX + key, value); return {key, value}; }
  catch(e){ console.error('localStorage set failed', e); return null; }
}
async function safeDelete(key, shared){
  if(hasClaudeStorage){
    try{ return await window.storage.delete(key, shared); }
    catch(e){ return null; }
  }
  try{ localStorage.removeItem(LS_PREFIX + key); return {key, deleted:true}; }
  catch(e){ return null; }
}

function genId(){
  const n = () => Math.floor(1000 + Math.random()*9000);
  return `AYB-${n()}-${n()}`;
}

async function loadIndex(){
  const raw = await safeGet('patients-index', true);
  index = raw ? JSON.parse(raw) : [];
  if(index.length === 0){
    await seedSamplePatient();
  }
}

async function seedSamplePatient(){
  const sample = {
    id: genId(),
    name: 'Ramesh Kulkarni',
    age: 58,
    gender: 'Male',
    bloodGroup: 'B+',
    allergies: ['Dust', 'Peanuts'],
    medicationAllergies: ['Penicillin'],
    currentMedications: ['Metformin 500mg — twice daily', 'Amlodipine 5mg — once daily'],
    lastDoctor: 'Dr. S. Iyer, Cardiology (12 Jun 2026)',
    emergencyContact: 'Sunita Kulkarni (wife) — +91 98765 43210',
    updated: new Date().toISOString()
  };
  await savePatient(sample, true);
}

function renderPatientList(){
  const q = (document.getElementById('search').value || '').toLowerCase();
  const filtered = index.filter(p => p.name.toLowerCase().includes(q) || p.id.toLowerCase().includes(q));
  if(filtered.length === 0){
    patientListEl.innerHTML = '<div class="empty-list">No patients found.</div>';
    return;
  }
  patientListEl.innerHTML = filtered.map(p => `
    <div class="patient-row ${p.id===selectedId ? 'selected':''}" data-id="${p.id}">
      <span class="pname">${escapeHtml(p.name)}</span>
      <span class="pblood">${p.bloodGroup}</span>
    </div>
  `).join('');
  patientListEl.querySelectorAll('.patient-row').forEach(row => {
    row.addEventListener('click', () => {
      selectedId = row.dataset.id;
      cardFlipped = false;
      currentView = 'registry';
      updateNav();
      renderPatientList();
      renderStage();
    });
  });
}

function escapeHtml(str){
  const d = document.createElement('div');
  d.textContent = str ?? '';
  return d.innerHTML;
}

function buildQrPayload(p){
  return JSON.stringify({
    id: p.id, n: p.name, ag: p.age, g: p.gender, bg: p.bloodGroup,
    al: p.allergies, ma: p.medicationAllergies, cm: p.currentMedications,
    ld: p.lastDoctor, ec: p.emergencyContact, up: p.updated
  });
}

function renderCardView(p){
  const payload = buildQrPayload(p);
  stage.innerHTML = `
    <div class="card-wrap">
      <div class="flip-scene">
        <div class="flip-card ${cardFlipped ? 'flipped':''}" id="flipCard">
          <div class="face face-front">
            <div class="card-top">
              <span class="scheme-label">Swasthya Card · demo</span>
            </div>
            <div class="card-name">${escapeHtml(p.name)}</div>
            <div class="card-id">${p.id} · ${p.age}y · ${p.gender}</div>
            <div class="card-bottom">
              <span class="blood-chip">${p.bloodGroup}</span>
              <div class="qr-stamp" id="qrFront"></div>
            </div>
          </div>
          <div class="face face-back">
            <p class="back-title">Allergies</p>
            <div class="back-section">${(p.allergies||[]).map(a=>`<span class="allergy-pill">${escapeHtml(a)}</span>`).join('') || '<span class="back-value">None recorded</span>'}</div>
            <p class="back-title">Medication allergies</p>
            <div class="back-section">${(p.medicationAllergies||[]).map(a=>`<span class="allergy-pill">${escapeHtml(a)}</span>`).join('') || '<span class="back-value">None recorded</span>'}</div>
            <p class="back-title">Current medications</p>
            <div class="back-section">${(p.currentMedications||[]).map(a=>`<span class="med-pill">${escapeHtml(a)}</span>`).join('') || '<span class="back-value">None recorded</span>'}</div>
            <p class="back-title">Last visited doctor</p>
            <div class="back-section"><span class="back-value">${escapeHtml(p.lastDoctor)||'—'}</span></div>
            <p class="back-title">Emergency contact</p>
            <div class="back-section"><span class="back-value">${escapeHtml(p.emergencyContact)||'—'}</span></div>
          </div>
        </div>
      </div>
      <div class="card-controls">
        <button class="btn-secondary" id="flipBtn">Flip card</button>
        <button class="btn-secondary" id="editBtn">Edit details</button>
        <button class="btn-primary" id="simulateScanBtn">Simulate QR scan ↗</button>
      </div>
      <button class="payload-toggle" id="payloadToggle">View raw QR payload</button>
      <pre class="payload-box" id="payloadBox">${escapeHtml(payload)}</pre>
    </div>
  `;
  new QRCode(document.getElementById('qrFront'), {
    text: payload, width: 56, height: 56,
    colorDark: '#1C2321', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.L
  });
  document.getElementById('flipBtn').onclick = () => {
    cardFlipped = !cardFlipped;
    document.getElementById('flipCard').classList.toggle('flipped');
  };
  document.getElementById('editBtn').onclick = () => renderFormView(p);
  document.getElementById('simulateScanBtn').onclick = () => {
    currentView = 'scan';
    updateNav();
    renderStage(p.id);
  };
  document.getElementById('payloadToggle').onclick = () => {
    document.getElementById('payloadBox').classList.toggle('show');
  };
}

function renderFormView(existing){
  const p = existing || {
    id: genId(), name:'', age:'', gender:'Male', bloodGroup:'O+',
    allergies:[], medicationAllergies:[], currentMedications:[],
    lastDoctor:'', emergencyContact:''
  };
  const isNew = !existing;
  stage.innerHTML = `
    <h3 style="margin-top:0;color:var(--ink-light);font-family:'Fraunces',serif;font-weight:600;">${isNew ? 'Register new patient' : 'Edit patient — ' + p.id}</h3>
    <div class="form-grid">
      <div><label>Full name</label><input id="f_name" value="${escapeHtml(p.name)}"></div>
      <div><label>Age</label><input id="f_age" type="number" min="0" value="${p.age}"></div>
      <div><label>Gender</label>
        <select id="f_gender">
          ${['Male','Female','Other'].map(g=>`<option ${g===p.gender?'selected':''}>${g}</option>`).join('')}
        </select>
      </div>
      <div><label>Blood group</label>
        <select id="f_blood">
          ${bloodGroups.map(b=>`<option ${b===p.bloodGroup?'selected':''}>${b}</option>`).join('')}
        </select>
      </div>
      <div class="full"><label>Allergies (comma separated)</label><input id="f_allergies" value="${escapeHtml((p.allergies||[]).join(', '))}"></div>
      <div class="full"><label>Medication allergies (comma separated)</label><input id="f_medallergies" value="${escapeHtml((p.medicationAllergies||[]).join(', '))}"></div>
      <div class="full"><label>Current medications (comma separated, with dosage)</label><textarea id="f_meds">${escapeHtml((p.currentMedications||[]).join(', '))}</textarea></div>
      <div class="full"><label>Last visited doctor</label><input id="f_lastdoc" value="${escapeHtml(p.lastDoctor)}" placeholder="Dr. name, specialty (date)"></div>
      <div class="full"><label>Emergency contact</label><input id="f_emergency" value="${escapeHtml(p.emergencyContact)}" placeholder="Name (relation) — phone"></div>
    </div>
    <div class="form-actions">
      <button class="btn-primary" id="saveBtn">${isNew ? 'Register & generate card' : 'Save changes'}</button>
      <button class="btn-secondary" id="cancelBtn">Cancel</button>
      ${!isNew ? '<button class="btn-danger" id="deleteBtn">Delete record</button>' : ''}
    </div>
  `;
  document.getElementById('saveBtn').onclick = async () => {
    const record = {
      id: p.id,
      name: document.getElementById('f_name').value.trim() || 'Unnamed patient',
      age: Number(document.getElementById('f_age').value) || 0,
      gender: document.getElementById('f_gender').value,
      bloodGroup: document.getElementById('f_blood').value,
      allergies: splitList(document.getElementById('f_allergies').value),
      medicationAllergies: splitList(document.getElementById('f_medallergies').value),
      currentMedications: splitList(document.getElementById('f_meds').value),
      lastDoctor: document.getElementById('f_lastdoc').value.trim(),
      emergencyContact: document.getElementById('f_emergency').value.trim(),
      updated: new Date().toISOString()
    };
    await savePatient(record, isNew);
    selectedId = record.id;
    cardFlipped = false;
    renderPatientList();
    renderCardView(record);
  };
  document.getElementById('cancelBtn').onclick = () => {
    if(existing) renderCardView(existing); else renderStage();
  };
  if(!isNew){
    document.getElementById('deleteBtn').onclick = async () => {
      if(!confirm('Delete this patient record? This cannot be undone.')) return;
      await deletePatient(p.id);
      selectedId = null;
      renderPatientList();
      renderStage();
    };
  }
}

function splitList(str){
  return str.split(',').map(s=>s.trim()).filter(Boolean);
}

async function savePatient(record, isNew){
  await safeSet('patient:' + record.id, JSON.stringify(record), true);
  const i = index.findIndex(x => x.id === record.id);
  const summary = { id: record.id, name: record.name, bloodGroup: record.bloodGroup };
  if(i >= 0) index[i] = summary; else index.push(summary);
  await safeSet('patients-index', JSON.stringify(index), true);
}

async function deletePatient(id){
  await safeDelete('patient:' + id, true);
  index = index.filter(x => x.id !== id);
  await safeSet('patients-index', JSON.stringify(index), true);
}

function renderScanView(prefilledId){
  const options = index.map(p => `<option value="${p.id}" ${p.id===prefilledId?'selected':''}>${escapeHtml(p.name)} — ${p.id}</option>`).join('');
  stage.innerHTML = `
    <h3 style="margin-top:0;color:var(--ink-light);font-family:'Fraunces',serif;font-weight:600;">Emergency scan simulation</h3>
    <p class="scan-hint">In real life, a paramedic or doctor scans the patient's QR. Here, pick a patient to simulate what the scanner would decode instantly — no login needed.</p>
    <div class="qr-select">
      <label>Select patient to simulate scanning</label>
      <select id="scanSelect">
        <option value="">— choose a patient —</option>
        ${options}
      </select>
    </div>
    <div id="scanOutput"></div>
  `;
  const sel = document.getElementById('scanSelect');
  sel.onchange = async () => {
    const id = sel.value;
    if(!id){ document.getElementById('scanOutput').innerHTML=''; return; }
    const raw = await safeGet('patient:' + id, true);
    if(!raw){ document.getElementById('scanOutput').innerHTML = '<p class="scan-hint">Record not found.</p>'; return; }
    const p = JSON.parse(raw);
    document.getElementById('scanOutput').innerHTML = `
      <div class="scan-result">
        <h2>${escapeHtml(p.name)}</h2>
        <p class="scan-hint" style="margin:0;">${p.id} · ${p.age}y · ${p.gender} · updated ${new Date(p.updated).toLocaleString()}</p>
        <div class="scan-grid">
          <div class="scan-field danger"><div class="k">Blood group</div><div class="v">${p.bloodGroup}</div></div>
          <div class="scan-field danger"><div class="k">Allergies</div><div class="v">${(p.allergies||[]).join(', ') || 'None recorded'}</div></div>
          <div class="scan-field danger"><div class="k">Medication allergies</div><div class="v">${(p.medicationAllergies||[]).join(', ') || 'None recorded'}</div></div>
          <div class="scan-field"><div class="k">Current medications</div><div class="v">${(p.currentMedications||[]).join(', ') || 'None recorded'}</div></div>
          <div class="scan-field"><div class="k">Last visited doctor</div><div class="v">${escapeHtml(p.lastDoctor) || '—'}</div></div>
          <div class="scan-field"><div class="k">Emergency contact</div><div class="v">${escapeHtml(p.emergencyContact) || '—'}</div></div>
        </div>
      </div>
    `;
  };
  if(prefilledId){ sel.value = prefilledId; sel.onchange(); }
}

function updateNav(){
  document.querySelectorAll('#nav button').forEach(b => {
    b.classList.toggle('active', b.dataset.view === currentView);
  });
}

function renderStage(scanPrefill){
  if(currentView === 'scan'){
    renderScanView(scanPrefill);
    return;
  }
  if(!selectedId){
    stage.innerHTML = '<div class="placeholder">Select a patient from the list, or register a new one, to view their health ID card.</div>';
    return;
  }
  safeGet('patient:' + selectedId, true).then(raw => {
    if(!raw){ stage.innerHTML = '<div class="placeholder">Record not found.</div>'; return; }
    renderCardView(JSON.parse(raw));
  });
}

document.getElementById('newPatientBtn').onclick = () => {
  selectedId = null;
  currentView = 'registry';
  updateNav();
  renderPatientList();
  renderFormView(null);
};
document.getElementById('search').addEventListener('input', renderPatientList);
document.querySelectorAll('#nav button').forEach(b => {
  b.addEventListener('click', () => {
